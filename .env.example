# ─────────────────────────────────────────────────────────────────────────
# Oak & Sparrow .com — environment template
# Copy to `.env.local` for local dev. Set the same keys in the Vercel project
# Environment Variables for production. Everything here is OPTIONAL: the public
# build runs fully without any of these. They exist to wire the two seams.
# ─────────────────────────────────────────────────────────────────────────

# ── Seam 1: live Gatekeeper engine ──────────────────────────────────────
# When set, /api/classify proxies to the live Gatekeeper /evaluate endpoint
# instead of returning the in-browser demonstration verdict.
# (See lib/classifier.ts -> classifyInput and app/api/classify/route.ts.)
GATEKEEPER_API_URL=
GATEKEEPER_CLIENT_ID=

# ── Seam 2: grounded answer model ───────────────────────────────────────
# When set, /api/chat answers via a model grounded on the FULL knowledge base
# (content/seam2_knowledge_base.json) with a strict "answer only from this,
# never invent numbers" instruction — the model reads meaning, so it routes
# questions correctly. Left empty, answers come from intent-aware retrieval
# over the same base (zero external calls, never guesses). See
# docs/seam2-knowledge-base.md.
# Default model id if you wire Anthropic: claude-opus-4-8
ANTHROPIC_API_KEY=
CHAT_MODEL=claude-opus-4-8

# ── Onboarding scheduling ────────────────────────────────────────────────
# The "book the onboarding call" link. Point at your scheduling tool.
NEXT_PUBLIC_SCHEDULING_URL=https://cal.com/oakandsparrow/onboarding

# ── Onboarding lead capture (optional) ───────────────────────────────────
# When set, /api/onboarding forwards submitted leads to this webhook
# (e.g. a CRM, Zapier, or Slack incoming webhook). Left empty, leads are
# logged server-side only.
ONBOARDING_WEBHOOK_URL=
